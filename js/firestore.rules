rules_version = '2';
// Reglas de Firestore para GalaxWiki (Pirate Galaxy).
// Copia este contenido en Firebase Console → Firestore → Reglas,
// o despliega con: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: verifica si el usuario es admin ──
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Helper: verifica si solo se está actualizando postCount ──
    // Esto permite a cualquier usuario autenticado incrementar/decrementar
    // el contador de respuestas de un hilo sin ser el autor del hilo.
    function onlyUpdatingPostCount() {
      return request.auth != null &&
             request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['postCount', 'updatedAt', 'lastPostAt', 'lastPostAuthor']);
    }

    // ── Usuarios ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, update: if isAdmin();
    }

    // ── Favoritos ──
    match /users/{userId}/favorites/{favId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Planos de usuario ──
    match /users/{userId}/blueprints/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Wiki: lectura pública, escritura solo admins ──
    match /ships/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /components/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /enemies/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /systems/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /planets/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /missions/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /paints/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /drones/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /cortex/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /gravitons/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Opciones (facciones, tipos, rarezas) ──
    match /factions/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /ship_types/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /component_types/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /component_rarities/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /enemy_types/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /paint_types/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /paint_rarities/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /drone_types/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Servidores, misc, conquista ──
    match /servers/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /misc_info/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /conquest_schedules/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── FORO ────────────────────────────────────────────────────────
    match /forum_categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /forum_threads/{threadId} {
      allow read: if true;
      // Cualquier usuario autenticado puede crear un hilo
      allow create: if request.auth != null;
      // El autor del hilo o un admin puede editar/borrar todo el documento
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.authorId || isAdmin() || onlyUpdatingPostCount());
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /forum_threads/{threadId}/posts/{postId} {
      allow read: if true;
      // Cualquier usuario autenticado puede crear un post (respuesta)
      allow create: if request.auth != null;
      // Solo el autor del post o un admin puede editar/borrar el post
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    // ────────────────────────────────────────────────────────────────

    // ── Noticias ──
    match /news/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /news/{newsId}/user_reactions/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Eventos ──
    match /events/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Historia del juego ──
    match /game_story/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Secciones especiales ──
    match /sirius_info/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /survival_guides/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /farming_routes/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /conquest_info/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /clan_info/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /map_markers/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Comentarios en diversas colecciones ──
    match /bestiary/{entryId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /planet_drops/{dropId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /planets/{planetId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /farming_routes/{routeId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /ships/{shipId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /enemies/{enemyId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /missions/{missionId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
                               (request.auth.uid == resource.data.authorId || isAdmin());
    }

    // ── Bestiary y drops ──
    match /bestiary/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /planet_drops/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Blueprints (wiki) ──
    match /blueprints/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Tracker de colección ──
    match /user_blueprints/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // ── Builds ──
    match /builds/{buildId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                       (request.auth.uid == resource.data.authorId || isAdmin());
      allow delete: if request.auth != null &&
                       (request.auth.uid == resource.data.authorId || isAdmin());
    }

    // ── Reportes ──
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }

    // ── Sirius extendida ──
    match /sirius_rings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /sirius_enemies/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /sirius_blueprints/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
